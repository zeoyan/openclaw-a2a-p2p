# Fully unattended mode requires a Tailscale auth key.
TS_AUTHKEY=tskey-example

# Local OpenClaw A2A identity
A2A_NAME=小爪
A2A_DESCRIPTION=OpenClaw A2A peer
A2A_SESSION_KEY=a2a-peer-inbox

# Optional: set your own bearer token instead of auto-generating one
# A2A_BEARER_TOKEN=replace-with-hex-token

# Optional: preconfigure one remote peer during bootstrap
# PEER_ID=claw-brother
# PEER_NAME=爪子哥
# PEER_AGENT_CARD_URL=http://100.x.y.z:18789/a2a/.well-known/agent-card.json
# PEER_BEARER_TOKEN=replace-with-peer-token
