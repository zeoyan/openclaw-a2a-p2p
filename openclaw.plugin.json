{
  "id": "a2a-p2p",
  "name": "A2A P2P",
  "description": "A2A v1.0 peer-to-peer gateway for OpenClaw with peer registry, Agent Card, JSON-RPC endpoint, and local task store.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "server": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "basePath": { "type": "string", "default": "/a2a", "description": "HTTP base path for the Agent Card and JSON-RPC routes." },
          "allowRemote": { "type": "boolean", "default": false, "description": "Allows non-loopback clients to call the plugin routes. This does not expose the node by itself; the OpenClaw gateway and network path must also be reachable." }
        }
      },
      "agentCard": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "default": "OpenClaw A2A Agent" },
          "description": { "type": "string", "default": "A2A-enabled OpenClaw agent" },
          "version": { "type": "string", "default": "1.0.0" },
          "url": { "type": "string", "description": "This node's own JSON-RPC endpoint, usually http(s)://HOST:PORT/a2a/jsonrpc. For cross-machine use, do not set this to 127.0.0.1 or localhost." },
          "provider": { "type": "string", "default": "OpenClaw" },
          "streaming": { "type": "boolean", "default": true },
          "pushNotifications": { "type": "boolean", "default": false },
          "skills": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string" },
                "name": { "type": "string" },
                "description": { "type": "string" }
              },
              "required": ["id", "name"]
            },
            "default": [
              {
                "id": "chat",
                "name": "chat",
                "description": "General-purpose text chat routed into OpenClaw"
              }
            ]
          }
        }
      },
      "routing": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "sessionKey": { "type": "string", "description": "Dedicated OpenClaw session for inbound A2A routing. Do not reuse a busy human chat session." },
          "mode": {
            "type": "string",
            "enum": ["subagent", "system-event"],
            "default": "subagent"
          },
          "waitTimeoutMs": { "type": "number", "minimum": 0, "default": 30000 }
        }
      },
      "security": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "inboundAuth": {
            "type": "string",
            "enum": ["none", "bearer"],
            "default": "bearer"
          },
          "token": { "type": "string" },
          "maxBodyBytes": { "type": "number", "minimum": 1024, "default": 262144 }
        }
      },
      "peers": {
        "type": "array",
        "default": [],
        "items": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "agentCardUrl": { "type": "string", "description": "Remote peer Agent Card URL, usually http(s)://PEER_HOST:PORT/a2a/.well-known/agent-card.json." },
            "description": { "type": "string" },
            "labels": { "type": "array", "items": { "type": "string" }, "default": [] },
            "auth": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "type": { "type": "string", "enum": ["none", "bearer"], "default": "none" },
                "token": { "type": "string" }
              }
            }
          },
          "required": ["id", "name", "agentCardUrl"]
        }
      }
    }
  }
}
